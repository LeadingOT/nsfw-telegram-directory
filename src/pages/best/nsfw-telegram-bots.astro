---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingCard from '../../components/ListingCard.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getCollection } from 'astro:content';

const allListings = await getCollection('listings');
const botPicks = ['ai-girlfriend-bot', 'premium-3d-hentai-bot'];
const stickerPicks = ['dolan-nsfw-stickers', 'letodoesart-nsfw-stickers', 'sexting-sticker-pack'];
const listings = botPicks.map(slug => allListings.find(l => l.data.slug === slug)).filter(Boolean);
const stickerListings = stickerPicks.map(slug => allListings.find(l => l.data.slug === slug)).filter(Boolean);

const faqs = [
  { question: "What are the best NSFW Telegram bots?", answer: "The verified-real picks are AI Girlfriend Bot for AI companion chat and Premium 3D Hentai Bot for 3D hentai content. Both were verified active on Telegram in July 2026. If you want in-chat extras rather than bots, the Dolan NSFW, LetoDoesArt NSFW, and Sexting sticker packs are installable directly in Telegram." },
  { question: "Are NSFW Telegram bots free?", answer: "Pricing varies by bot. Many NSFW bots offer a free tier and gate heavier usage behind a paid plan — check each bot's /start message or pinned info for current pricing before committing. Sticker packs are free to add once you open the pack link in Telegram." },
  { question: "How do NSFW Telegram bots work?", answer: "You start a chat with the bot by clicking its link or searching its username. Then you interact through text commands or buttons. AI chat bots use language models for conversation, while content bots deliver media inside the bot chat." },
];
---

<BaseLayout
  title="Best NSFW Telegram Bots (2026) — AI Chat, Hentai & Sticker Packs"
  description="Discover verified-real NSFW Telegram bots for AI chat and 3D hentai content, plus installable NSFW sticker packs. Every pick verified active in July 2026."
>
  <article class="max-w-4xl">
    <h1 class="text-4xl font-bold mb-4">Best NSFW Telegram Bots (2026)</h1>
    <p class="text-lg text-gray-400 mb-8">
      From AI companion chat to 3D hentai content and installable sticker packs, here are the NSFW bots and add-ons you can use directly in Telegram — every one verified active on t.me in July 2026.
    </p>

    <div class="bg-blue-950 border border-blue-800 rounded-lg p-4 mb-8">
      <h2 class="font-semibold text-blue-300 mb-2">🏆 Our Top Pick: AI Girlfriend Bot</h2>
      <p class="text-sm text-blue-400">Start with AI Girlfriend Bot — an AI girlfriend chat bot you message directly in Telegram, no separate app needed. Verified active July 2026.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
      {listings.map((listing) => listing && (
        <ListingCard {...listing.data} />
      ))}
    </div>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Installable Extras: NSFW Sticker Packs</h2>
      <p class="text-gray-400 text-sm mb-4">
        Not bots, but worth a spot here: these sticker packs install into Telegram once and then work in any chat. All three verified active July 2026.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {stickerListings.map((listing) => listing && (
          <ListingCard {...listing.data} />
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Types of NSFW Telegram Bots</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
          <h3 class="font-semibold mb-2">🤖 AI Chat Bots</h3>
          <p class="text-gray-400">Simulate conversations with AI personalities. Good for roleplay, companionship, and adult chat. AI Girlfriend Bot is our verified pick in this category.</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
          <h3 class="font-semibold mb-2">🎨 Hentai & Content Bots</h3>
          <p class="text-gray-400">Deliver adult artwork and animation inside a bot chat. Premium 3D Hentai Bot is the verified option here for 3D hentai content.</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
          <h3 class="font-semibold mb-2">😈 NSFW Sticker Packs</h3>
          <p class="text-gray-400">Installable packs like Dolan NSFW, LetoDoesArt NSFW, and the Sexting pack. Add once, use in any Telegram chat.</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
          <h3 class="font-semibold mb-2">✅ How We Picked</h3>
          <p class="text-gray-400">Every bot and pack on this page was verified active on t.me in July 2026. Anything we couldn't confirm exists was removed from the list.</p>
        </div>
      </div>
    </section>

    <FAQSection faqs={faqs} />
  </article>
</BaseLayout>
